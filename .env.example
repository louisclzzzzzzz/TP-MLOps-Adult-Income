# Copy this file to .env for local development.
# Never commit .env to Git.

# Port on which uvicorn will listen (default: 8000)
# Render and most cloud platforms inject $PORT automatically.
PORT=8000

# MLflow tracking URI (optional — defaults to a local SQLite file)
# For a remote tracking server, set this to your MLflow server URL.
# MLFLOW_TRACKING_URI=http://my-mlflow-server:5000

# Artifacts directory (optional — defaults to src/mlops_tp/artifacts/)
# ARTIFACTS_DIR=/path/to/artifacts
